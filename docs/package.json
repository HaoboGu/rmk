{
  "name": "rmk-rspress",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "node fetch-docs.js",
    "build": "rspress build",
    "check": "prettier .",
    "dev": "rspress dev",
    "format": "prettier . --write",
    "preview": "rspress preview"
  },
  "dependencies": {
    "@rspress/core": "^2.0.3"
  },
  "devDependencies": {
    "@iconify/json": "^2.2.400",
    "@iconify/tailwind4": "^1.0.6",
    "@rspress/plugin-sitemap": "^2.0.3",
    "@tailwindcss/postcss": "^4.1.16",
    "@types/node": "^24.10.9",
    "@types/react": "^19.2.2",
    "prettier": "3.6.2",
    "tailwindcss": "^4.1.16"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "core-js"
    ],
    "overrides": {
      "@rspress/core": "github:liyang8246/rspress#fix/core-dotted-version-prefix-built&path:/packages/core",
      "@rspress/shared": "github:liyang8246/rspress#fix/core-dotted-version-prefix-built&path:/packages/shared"
    }
  }
